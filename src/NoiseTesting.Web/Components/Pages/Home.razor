@page "/"
@using NoiseTesting.Imaging.Services
@using NoiseTesting.Noise.Services

<PageTitle>Home</PageTitle>

<img src="data:image/png;base64,@Convert.ToBase64String(GenerateNoiseImage())" style="border: 1px solid #000" />

@code
{
	private byte[] GenerateNoiseImage()
	{
		ImageGenerator imageGenerator = new ImageGenerator();
		PerlinNoiseGenerator noiseGenerator = new PerlinNoiseGenerator(3);

		float[,] noise = noiseGenerator.GenerateNoise(256, 64, 5, 0, 0);
		return imageGenerator.Generate(noise);
	}
}
